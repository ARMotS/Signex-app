# ─── Signex Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit your .env file to version control.
# ───────────────────────────────────────────────────────────────────────────

# ─── Database ──────────────────────────────────────────────────────────────
# PostgreSQL connection strings.
#
# DATABASE_URL: Used by Prisma CLI (prisma migrate, prisma db push)
# DATABASE_URL_DIRECT: Used by the application runtime (PrismaClient)
#   Must be a standard postgresql:// URL (TCP connection)

DATABASE_URL="postgresql://user:password@host:5432/dbname"
DATABASE_URL_DIRECT="postgresql://user:password@host:5432/dbname"

# ─── Session ───────────────────────────────────────────────────────────────
# REQUIRED — the app will not start without this.
# Generate a strong random secret with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

SESSION_SECRET="CHANGE_ME_GENERATE_A_RANDOM_SECRET"

# ─── Invoice Folder ───────────────────────────────────────────────────────
# Path to local or shared network folder containing PDF invoices.
# Leave empty to use the default ./invoices folder.

INVOICE_FOLDER_PATH=

# ─── Trip Sheet Folder ────────────────────────────────────────────────────
# Path to folder containing trip sheet CSV/Excel files.
# Can also be set via the admin Settings page.

TRIP_SHEET_FOLDER_PATH=

# ─── Contacts / AI ───────────────────────────────────────────────────────
# Anthropic API key for AI-powered contact extraction (optional)

ANTHROPIC_API_KEY=

# ─── OneDrive (Microsoft Graph API) ──────────────────────────────────────
# Required for OneDrive cloud folder sync.
# Register an app at https://portal.azure.com → App registrations
# Redirect URI: https://your-app.vercel.app/api/auth/microsoft/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=

# ─── App URL ─────────────────────────────────────────────────────────────
# Used for constructing callback URLs. Set to your production domain.

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Email (SMTP) ────────────────────────────────────────────────────────
# Used for sending delivery notifications to contacts.

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_FROM_NAME=Signex Deliveries
COMPANY_NAME=Signex

# ─── Multi-Tenant ─────────────────────────────────────────────────────────
# Email address for the super admin account (first user created on setup)

SUPER_ADMIN_EMAIL=your@email.com
